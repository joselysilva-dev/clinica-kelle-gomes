{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    }
  },

  "include": ["src"]
}